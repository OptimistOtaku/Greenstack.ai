# GreenStack.ai Environment Configuration
# Copy this file to .env and fill in your values

# Server port (Cloud Run expects 8080)
PORT=8080

# Google Gemini API Key (Required)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Google Cloud Service Account (Optional — for BigQuery & Translation)
# Path to your service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=path_to_your_gcp_service_account.json
